rules_version = '2';

// Firebase Storage security rules for GitAlong
service firebase.storage {
  match /b/{bucket}/o {
    
    // Profile pictures - users can upload/read their own profile pictures
    match /profile_pictures/{userId}_{timestamp}.jpg {
      allow read: if true; // Public read access for profile pictures
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024  // 5MB limit
        && request.resource.contentType.matches('image/.*');
    }
    
    // Legacy profile picture format
    match /profile_pictures/{userId}.jpg {
      allow read: if true; // Public read access for profile pictures
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024  // 5MB limit
        && request.resource.contentType.matches('image/.*');
    }
    
    // Project images and assets
    match /project_assets/{userId}/{fileName} {
      allow read: if true; // Public read access for project assets
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024  // 10MB limit
        && request.resource.contentType.matches('image/.*');
    }
    
    // User documents and files
    match /user_files/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 50 * 1024 * 1024; // 50MB limit
    }
    
    // Temporary uploads
    match /temp/{userId}/{fileName} {
      allow read, write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024  // 20MB limit
        && resource.timeCreated < request.time + duration.value(1, 'd'); // Auto-delete after 1 day
    }
    
    // App assets (public read only)
    match /app_assets/{allPaths=**} {
      allow read: if true;
      allow write: if false; // Only admin can write (done via Firebase Admin SDK)
    }
    
    // Health check file
    match /_health_check {
      allow read: if true;
      allow write: if false;
    }
    
    // Default deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
