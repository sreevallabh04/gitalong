rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null; // Allow other users to read profiles for search/messaging
    }
    
    // User's subcollections
    match /users/{userId}/{subcollection=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Recent searches - users can manage their own searches
    match /users/{userId}/recent_searches/{searchId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // User projects
    match /users/{userId}/projects/{projectId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Welcome emails - allow authenticated users to read/write their own emails
    match /welcome_emails/{emailId} {
      allow read, write: if request.auth != null && 
        (resource == null || resource.data.user_id == request.auth.uid);
    }
    
    // Email analytics - allow authenticated users to write analytics
    match /email_analytics/{analyticsId} {
      allow read, write: if request.auth != null;
    }
    
    // Messages - users can read/write messages they're involved in
    match /messages/{messageId} {
      allow read, write: if request.auth != null && 
        (resource == null || 
         request.auth.uid == resource.data.senderId || 
         request.auth.uid == resource.data.receiverId);
    }
    
    // Conversations - users can access conversations they're part of
    match /conversations/{conversationId} {
      allow read, write: if request.auth != null && 
        (resource == null ||
         request.auth.uid in resource.data.participants);
    }
    
    // Conversation messages
    match /conversations/{conversationId}/messages/{messageId} {
      allow read, write: if request.auth != null;
    }
    
    // Projects - public read, authenticated write for own projects
    match /projects/{projectId} {
      allow read: if true; // Public read access for project discovery
      allow write: if request.auth != null && 
        (resource == null || request.auth.uid == resource.data.ownerId);
    }
    
    // Project collaborators
    match /projects/{projectId}/collaborators/{collaboratorId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (resource == null || request.auth.uid == resource.data.userId);
    }
    
    // GitHub data - users can manage their own GitHub data
    match /github_data/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Search results - authenticated users can read search results
    match /search_results/{searchId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Notifications - users can manage their own notifications
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null && 
        (resource == null || request.auth.uid == resource.data.userId);
    }
    
    // User activity/analytics
    match /user_activity/{activityId} {
      allow read, write: if request.auth != null && 
        (resource == null || request.auth.uid == resource.data.userId);
    }
    
    // Skills and interests - public read, authenticated write
    match /skills/{skillId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /interests/{interestId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Reports and feedback
    match /reports/{reportId} {
      allow read, write: if request.auth != null;
    }
    
    // App metadata - public read, admin write only
    match /app_metadata/{docId} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.token.admin == true;
    }
    
    // Rate limiting and security
    match /rate_limits/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Catch-all for any other collections - require authentication
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
  
  // Functions to help with rules
  function isAuthenticated() {
    return request.auth != null;
  }
  
  function isOwner(userId) {
    return request.auth != null && request.auth.uid == userId;
  }
  
  function isParticipant(participants) {
    return request.auth != null && request.auth.uid in participants;
  }
} 