# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key  # Settings → API → service_role

# ─── GitHub API ──────────────────────────────────────────────────────────────
# Optional but recommended — increases rate limit from 60 to 5000 req/hour
GITHUB_TOKEN=ghp_your_personal_access_token

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=GitAlong API
APP_VERSION=1.0.0
DEBUG=false

# ─── CORS (comma-separated, * = allow all) ───────────────────────────────────
# For production, restrict to your Flutter app's bundle ID or domain
ALLOWED_ORIGINS=*

# ─── Recommendation Tuning ───────────────────────────────────────────────────
RECOMMENDATION_LIMIT=20
CANDIDATE_POOL_MULTIPLIER=5
